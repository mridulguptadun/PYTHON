1. Student Class

    class Student:
        def __init__(self, name, age, marks):
            self.name = name
            self.age = age
            self.marks = marks
    
        def display(self):
            print("Name :", self.name)
            print("Age :", self.age)
            print("Marks :", self.marks)    
    
    s1 = Student("Mridul", 18, 92)
    s2 = Student("Rahul", 17, 85)
    s1.display()
    print()
    s2.display()

2. Rectangle Area

    class Rectangle:
        def __init__(self, length, width):
            self.length = length
