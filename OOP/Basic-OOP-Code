8. Bank Account

    class BankAccount:
        def __init__(self, name, balance):
            self.name = name
            self.balance = balance
    
        def deposit(self, amount):
            self.balance += amount
            print("New Balance :", self.balance)
    
    acc = BankAccount("Mridul", 10000)
    acc.deposit(2500)

9. Calculator

    class Calculator:
        def __init__(self, a, b):
            self.a = a
            self.b = b
    
        def add(self):
            print("Addition :", self.a + self.b)
    
        def subtract(self):
            print("Subtraction :", self.a - self.b)
    
        def multiply(self):
            print("Multiplication :", self.a * self.b)
    
    c = Calculator(20, 10)
    c.add()
    c.subtract()
    c.multiply()

