10) Log File Analyzer
    info = 0
    error = 0
    warning = 0
    with open("log.txt", "r") as file:
        for line in file:
            if line.startswith("INFO"):
                info += 1
    
            elif line.startswith("ERROR"):
                error += 1
    
            elif line.startswith("WARNING"):
                warning += 1
    
    print("INFO :", info)
    print("ERROR :", error)
    print("WARNING :", warning)

11) Find Duplicate Lines
    seen = set()
    duplicates = set()
    with open("data.txt", "r") as file:
        for line in file:
            line = line.strip()
            if line in seen:
                duplicates.add(line)
            else:
                seen.add(line)
    print(duplicates)

12) Reverse File Content
    with open("data.txt", "r") as file:
        lines = file.readlines()
    with open("reverse.txt", "w") as file:
        for line in reversed(lines):
            file.write(line)

13) Compare Two Files
    with open("file1.txt", "r") as f1:
        data1 = f1.read()
    
    with open("file2.txt", "r") as f2:
        data2 = f2.read()
    
    if data1 == data2:
        print("Same File")
    
    else:
        print("Different File")

14) File Encryption (Simple Caesar Cipher)
    shift = 3   
    with open("message.txt", "r") as file:
        text = file.read()
    
    encrypted = ""    
    for ch in text:    
        encrypted += chr(ord(ch) + shift)
    
    with open("encrypted.txt", "w") as file:
        file.write(encrypted)
