1) Count Lines, Words, Characters
    lines = 0
    words = 0
    characters = 0
    
    with open("data.txt", "r") as file:    
        for line in file:
            lines += 1
            words += len(line.split())
            characters += len(line)   
    print("Lines :", lines)
    print("Words :", words)
    print("Characters :", characters)

2) Search a Word in File
    word = input("Enter word : ")
    with open("story.txt", "r") as file:
        for number, line in enumerate(file, start=1):
            if word.lower() in line.lower():
                print(f"Found in line {number}")
                print(line.strip())

3) Copy One File to Another
    with open("source.txt", "r") as source:
        with open("destination.txt", "w") as destination:
            for line in source:
                destination.write(line)
    print("Copied Successfully")

4) Remove Blank Lines
    with open("input.txt", "r") as file:
        lines = file.readlines()
    with open("output.txt", "w") as file:
        for line in lines:
            if line.strip() != "":
                file.write(line)

5) Count Frequency of Every Word
    frequency = {}
    with open("story.txt", "r") as file:
        for line in file:
            words = line.lower().split()
            for word in words:
                frequency[word] = frequency.get(word, 0) + 1
    print(frequency)

6) Find Longest Line
    longest = ""
    with open("data.txt", "r") as file:
        for line in file:
            if len(line) > len(longest):
                longest = line
    print(longest)

7) Merge Multiple Files
    files = ["a.txt", "b.txt", "c.txt"]
    with open("final.txt", "w") as output:
        for filename in files:
            with open(filename, "r") as file:
                output.write(file.read())
                output.write("\n")

